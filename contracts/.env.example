# Private key for the deployer account (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia RPC URL
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# USDC token address on Arbitrum Sepolia (replace with actual address)
# For testing, you can deploy a mock ERC20 or use an existing token
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Official USDC token address on Arbitrum mainnet
# Official Circle Faucet for USDC: https://faucet.circle.com/
USDC_OFFICIAL_ADDRESS_ON_ARBITRUM_SEPOLIA="0x3a3A65aAb0dd2A17E3F1947bA16138cd37d08c04"

# Arbiscan API key for contract verification (optional)
ARBISCAN_API_KEY=your_arbiscan_api_key_here
