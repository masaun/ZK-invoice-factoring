# Private key for the deployer account (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia RPC URL
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Etherscan (Arbiscan) API key for contract verification (optional)
ARBISCAN_API_KEY=your_arbiscan_api_key_here

# USDC token address on Arbitrum Sepolia (replace with actual address)
# For testing, you can deploy a mock ERC20 or use an existing token
USDC_ADDRESS_MOCK_ON_ARBITRUM_SEPOLIA="0x0000000000000000000000000000000000000000"

# Official USDC token address on Arbitrum mainnet
# Official Circle Faucet for USDC: https://faucet.circle.com/
USDC_ADDRESS_OFFICIAL_ON_ARBITRUM_SEPOLIA="0x3a3A65aAb0dd2A17E3F1947bA16138cd37d08c04"


#==========================================#
# Deployment Addresses on Arbitrum Sepolia #
#==========================================# 
# HonkVerifier contract address after deployment
HONK_VERIFIER_CONTRACT_ADDRESS=your_deployed_honk_verifier_address_here

# InvoiceRefactoringHonkVerifier contract address after deployment
INVOICE_REFACTORING_HONK_VERIFIER_CONTRACT_ADDRESS=your_deployed_invoice

# InvoiceFactoring contract address after deployment
INVOICE_FACTORING_CONTRACT_ADDRESS=your_deployed_contract_address_here


#=============================================================================#
# Deployment Addresses for the DataProtector of iExec TEE on Arbitrum Sepolia #
#=============================================================================# 
# HonkVerifier contract address after deployment
HONK_VERIFIER_CONTRACT_ADDRESS_USING_DATA_PROTECTOR=your_deployed_honk_verifier_address_using_data_protector here

# InvoiceRefactoringHonkVerifier contract address after deployment
INVOICE_REFACTORING_HONK_VERIFIER_CONTRACT_ADDRESS_USING_DATA_PROTECTOR=your_deployed_invoice_refactoring_honk_verifier_address_using_data_protector here

# InvoiceFactoring contract address after deployment
INVOICE_FACTORING_CONTRACT_ADDRESS_USING_DATA_PROTECTOR=your_deployed_contract_address_using_data_protector here